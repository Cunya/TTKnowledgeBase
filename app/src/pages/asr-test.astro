---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
const artifacts = [
  { name: 'Retained video', path: 'media/table-tennis/_biE-Dzy0aM/video.mp4', detail: '17.50 MiB · source retained for review' },
  { name: 'Extracted audio', path: 'media/table-tennis/_biE-Dzy0aM/audio.wav', detail: '14.92 MiB · mono PCM · 16 kHz' },
  { name: 'ASR subtitles', path: 'media/table-tennis/_biE-Dzy0aM/asr.vtt', detail: '13.0 KiB · private WebVTT' },
  { name: 'ASR segment JSON', path: 'media/table-tennis/_biE-Dzy0aM/asr.json', detail: '35.3 KiB · 129 timed segments' },
  { name: 'ASR normalized cache', path: 'data/normalized/table-tennis/asr/_biE-Dzy0aM.json', detail: 'Private normalized transcript record' },
  { name: 'Provenance manifest', path: 'data/manifests/table-tennis/media-asr/_biE-Dzy0aM.json', detail: 'Private hashes, paths, model, and retention state' },
];
---

<BaseLayout title="ASR test results" description="Local-only results and artifact inventory for the one-video media-ASR smoke test.">
  <section class="page-intro asr-intro">
    <a class="back-link" href={`${base}dashboard/`}>← Dashboard</a>
    <div class="eyebrow">Local experiment · completed</div>
    <h1>One video, fully traced.</h1>
    <p>The retained-media ASR smoke test completed on one table-tennis lesson. This page records what was created, what was verified, and which boundaries remain in place.</p>
    <div class="asr-status"><span class="status-dot"></span><strong>Completed</strong><span>21 July 2026</span><span>One-video scope</span></div>
  </section>

  <section class="asr-section" aria-labelledby="test-input">
    <div class="section-kicker">Test input</div>
    <div class="asr-input-grid">
      <div>
        <h2 id="test-input">3 Ways to Add Power Without Missing</h2>
        <p class="muted">Video ID <code>_biE-Dzy0aM</code> · 8m 09s · <a href="https://www.youtube.com/watch?v=_biE-Dzy0aM">Open source video ↗</a></p>
      </div>
      <div class="asr-callout"><strong>Transcript streams stayed separate</strong><span>The original cache remains <code>youtube_generated</code>. The ASR cache uses <code>local_asr</code> and its own segment namespace.</span></div>
    </div>
  </section>

  <section class="asr-section" aria-labelledby="results">
    <div class="section-kicker">Observed result</div>
    <h2 id="results">The smoke test produced a reviewable local record.</h2>
    <div class="metric-grid">
      <div class="metric-card"><strong>129</strong><span>ASR segments</span></div>
      <div class="metric-card"><strong>tiny</strong><span>faster-whisper model</span></div>
      <div class="metric-card"><strong>CPU</strong><span>portable execution profile</span></div>
      <div class="metric-card"><strong>local_asr</strong><span>transcript origin</span></div>
    </div>
    <div class="namespace-check">
      <div><span class="check-label">Caption cache</span><code>_biE-Dzy0aM:00000</code><small>youtube_generated</small></div>
      <div class="arrow" aria-hidden="true">→</div>
      <div><span class="check-label">ASR cache</span><code>_biE-Dzy0aM:asr:00000</code><small>local_asr · 129 segments</small></div>
    </div>
  </section>

  <section class="asr-section" aria-labelledby="materials">
    <div class="section-kicker">Created materials</div>
    <h2 id="materials">The private artifact set</h2>
    <p class="muted asr-lead">These names and metadata describe the local materials without loading their contents into the site.</p>
    <div class="artifact-list">
      {artifacts.map((artifact, index) => <div class="artifact-row">
        <span class="artifact-index">{String(index + 1).padStart(2, '0')}</span>
        <div><strong>{artifact.name}</strong><code>{artifact.path}</code></div>
        <span class="artifact-detail">{artifact.detail}</span>
      </div>)}
    </div>
  </section>

  <section class="asr-section" aria-labelledby="verification">
    <div class="section-kicker">Verification</div>
    <h2 id="verification">What passed</h2>
    <div class="verification-grid">
      <div><span class="pass">✓</span><strong>Artifact retention</strong><p>Video, audio, subtitles, JSON, and manifest were retained under ignored private paths.</p></div>
      <div><span class="pass">✓</span><strong>Boundary protection</strong><p>No ASR media or raw transcript entered <code>app/public/</code>.</p></div>
      <div><span class="pass">✓</span><strong>Pipeline health</strong><p>Publish completed with 345 concepts. Published artifacts and full validation passed.</p></div>
      <div><span class="pass">✓</span><strong>Regression checks</strong><p>46 tests passed and Ruff reported no issues.</p></div>
    </div>
  </section>

  <section class="asr-section asr-next" aria-labelledby="next">
    <div class="section-kicker">Next gates</div>
    <h2 id="next">Still deliberately experimental.</h2>
    <div class="next-grid">
      <p>Cleanup and deletion controls remain deferred. The retained media stays local until those controls are implemented.</p>
      <p>Caption comparison, ASR review-state validation, human gold-set review, and expansion beyond one video remain future work.</p>
    </div>
  </section>
</BaseLayout>

<style>
  .back-link { display: inline-block; margin-bottom: 42px; color: var(--green); font-size: 13px; font-weight: 750; text-decoration: none; }
  .back-link:hover { text-decoration: underline; }
  .asr-intro { max-width: 940px; }
  .asr-status { display: flex; flex-wrap: wrap; align-items: center; gap: 12px 22px; color: var(--muted); font-size: 12px; text-transform: uppercase; letter-spacing: .08em; }
  .asr-status strong { color: var(--green); }
  .status-dot { width: 9px; height: 9px; border-radius: 50%; background: var(--green); box-shadow: 0 0 0 5px color-mix(in srgb, var(--green) 14%, transparent); }
  .asr-section { padding: 58px 0; border-top: 1px solid var(--line); }
  .asr-section h2 { max-width: 760px; margin: 8px 0 30px; font-family: Georgia, serif; font-size: clamp(34px, 5vw, 58px); font-weight: 500; letter-spacing: -.04em; line-height: 1.02; }
  .asr-input-grid { display: grid; grid-template-columns: minmax(0, 1.25fr) minmax(260px, .75fr); gap: 34px; align-items: start; }
  .asr-input-grid h2 { margin: 0 0 12px; font-size: clamp(30px, 4vw, 50px); }
  .muted { color: var(--muted); line-height: 1.6; }
  .muted a { color: var(--green); }
  code { font-family: ui-monospace, SFMono-Regular, Consolas, monospace; font-size: .86em; }
  .asr-callout { display: grid; gap: 9px; padding: 20px; border-left: 3px solid var(--orange); background: color-mix(in srgb, var(--surface) 70%, transparent); line-height: 1.5; }
  .asr-callout span { color: var(--muted); font-size: 13px; }
  .metric-grid { display: grid; grid-template-columns: repeat(4, 1fr); border-top: 2px solid var(--ink); border-bottom: 1px solid var(--line); }
  .metric-card { display: grid; gap: 8px; padding: 23px 18px 23px 4px; border-right: 1px solid var(--line); }
  .metric-card:last-child { border-right: 0; }
  .metric-card strong { font-family: Georgia, serif; font-size: clamp(27px, 4vw, 46px); font-weight: 500; overflow-wrap: anywhere; }
  .metric-card span { color: var(--muted); font-size: 11px; text-transform: uppercase; letter-spacing: .1em; }
  .namespace-check { display: grid; grid-template-columns: 1fr 28px 1fr; gap: 18px; align-items: center; margin-top: 32px; padding: 20px 4px; border-bottom: 1px solid var(--line); }
  .namespace-check > div:not(.arrow) { display: grid; gap: 7px; }
  .check-label, .artifact-detail, .artifact-index { color: var(--muted); font-size: 10px; font-weight: 800; letter-spacing: .1em; text-transform: uppercase; }
  .namespace-check small { color: var(--muted); }
  .arrow { color: var(--orange); font-size: 22px; text-align: center; }
  .asr-lead { max-width: 620px; margin-top: -14px; }
  .artifact-list { border-top: 2px solid var(--ink); }
  .artifact-row { display: grid; grid-template-columns: 44px minmax(0, 1fr) minmax(180px, .55fr); gap: 20px; align-items: center; padding: 18px 4px; border-bottom: 1px solid var(--line); }
  .artifact-row > div { display: grid; gap: 7px; min-width: 0; }
  .artifact-row code { color: var(--green); overflow-wrap: anywhere; }
  .artifact-detail { letter-spacing: .04em; text-transform: none; line-height: 1.4; }
  .verification-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px; background: var(--line); border: 1px solid var(--line); }
  .verification-grid > div { display: grid; grid-template-columns: 28px 1fr; gap: 8px; padding: 22px; background: var(--surface); }
  .verification-grid p { grid-column: 2; margin: 0; color: var(--muted); font-size: 13px; line-height: 1.5; }
  .pass { color: var(--green); font-size: 20px; }
  .asr-next { padding-bottom: 90px; }
  .next-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 28px; max-width: 800px; }
  .next-grid p { margin: 0; color: var(--muted); line-height: 1.65; }
  @media (max-width: 700px) {
    .asr-input-grid, .next-grid, .verification-grid { grid-template-columns: 1fr; }
    .metric-grid { grid-template-columns: repeat(2, 1fr); }
    .metric-card:nth-child(2) { border-right: 0; }
    .namespace-check { grid-template-columns: 1fr; }
    .arrow { transform: rotate(90deg); }
    .artifact-row { grid-template-columns: 30px 1fr; }
    .artifact-detail { grid-column: 2; }
  }
</style>
