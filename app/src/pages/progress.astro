---
import BaseLayout from '../layouts/BaseLayout.astro';
import { existsSync, readFileSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import corpusData from '../../public/data/kbs/table-tennis/corpus.json';
import globalCatalogData from '../data/globalttstudio-videos.json';
import sixthBatchData from '../data/tt-spinmaster-sixth-batch.json';
import progressData from '../data/generated/table-tennis-progress.json';
import type { Corpus } from '../types';

const corpus = corpusData as Corpus;
const sourceVideos = (channel: string) => corpus.videos.filter((video) => video.channel_name === channel);
const spinMasterVideos = sourceVideos('TT SpinMaster');
const globalVideos = sourceVideos('GlobalTTStudio');
const globalPublishedIds = new Set(globalVideos.map((video) => video.id));
const generatedProgress = progressData as { generated_at: string; totals: Record<string, number>; sources: Array<Record<string, string | number>>; members_only_ids: string[] };
const generatedTotals = generatedProgress.totals;
const generatedSource = (id: string) => generatedProgress.sources.find((source) => source.id === id) ?? {};
const spinMasterProgress = generatedSource('free-coach-brad-han');
const globalProgress = generatedSource('global-tt-studio');
const globalInaccessibleIds = new Set(generatedProgress.members_only_ids);
const globalCatalogVideos = globalCatalogData.videos;
const sixthBatchVideos = sixthBatchData.videos.filter((video) => !globalPublishedIds.has(video.id) && !spinMasterVideos.some((published) => published.id === video.id));
const globalCatalogState = (id: string) => globalPublishedIds.has(id) ? 'Published' : globalInaccessibleIds.has(id) ? 'Members-only' : 'Discovered';
const globalEligibleCount = Number(globalProgress.eligible ?? globalVideos.length);
const globalInaccessibleCount = Number(globalProgress.members_only ?? globalInaccessibleIds.size);
const globalConfiguredCount = Number(globalProgress.configured ?? globalEligibleCount + globalInaccessibleCount);
const spinMasterConfiguredCount = Number(spinMasterProgress.configured ?? spinMasterVideos.length + sixthBatchVideos.length);
const totalEligibleCount = Number(generatedTotals.eligible ?? spinMasterConfiguredCount + globalEligibleCount);
const totalConfiguredCount = Number(generatedTotals.configured ?? spinMasterConfiguredCount + globalConfiguredCount);
const percent = (value: number, total: number) => total ? Math.round((value / total) * 100) : 0;
const summaryStage = (value: number, total: number) => `${value} (${percent(value, total)}%)`;
const sourceProgress = [
  {
    name: String(spinMasterProgress.name ?? 'TT SpinMaster'),
    detail: `${spinMasterProgress.eligible ?? spinMasterConfiguredCount} eligible videos`,
    stages: [
      { label: 'Configured from discovery', value: Number(spinMasterProgress.configured ?? spinMasterConfiguredCount), total: Number(spinMasterProgress.discovered ?? spinMasterConfiguredCount) },
      { label: 'Eligible', value: Number(spinMasterProgress.eligible ?? spinMasterConfiguredCount), total: Number(spinMasterProgress.configured ?? spinMasterConfiguredCount) },
      { label: 'Ingested', value: Number(spinMasterProgress.ingested ?? spinMasterConfiguredCount), total: Number(spinMasterProgress.eligible ?? spinMasterConfiguredCount) },
      { label: 'Extracted', value: Number(spinMasterProgress.extracted ?? spinMasterConfiguredCount), total: Number(spinMasterProgress.eligible ?? spinMasterConfiguredCount) },
      { label: 'Fully reviewed', value: Number(spinMasterProgress.reviewed ?? 0), total: Number(spinMasterProgress.eligible ?? spinMasterConfiguredCount) },
      { label: 'Published', value: Number(spinMasterProgress.published ?? spinMasterVideos.length), total: Number(spinMasterProgress.eligible ?? spinMasterConfiguredCount) },
    ],
  },
  {
    name: String(globalProgress.name ?? 'GlobalTTStudio'),
    detail: `${globalEligibleCount} eligible · ${globalInaccessibleCount} members-only`,
    stages: [
      { label: 'Configured from discovery', value: Number(globalProgress.configured ?? globalConfiguredCount), total: Number(globalProgress.discovered ?? globalConfiguredCount) },
      { label: 'Eligible', value: globalEligibleCount, total: globalConfiguredCount },
      { label: 'Ingested', value: Number(globalProgress.ingested ?? globalEligibleCount), total: globalEligibleCount },
      { label: 'Extracted', value: Number(globalProgress.extracted ?? globalEligibleCount), total: globalEligibleCount },
      { label: 'Fully reviewed', value: Number(globalProgress.reviewed ?? 0), total: globalEligibleCount },
      { label: 'Published', value: Number(globalProgress.published ?? globalEligibleCount), total: globalEligibleCount },
    ],
  },
  {
    name: 'Total configured',
    detail: `${totalEligibleCount} eligible videos`,
    stages: [
      { label: 'Configured from discovery', value: totalConfiguredCount, total: Number(generatedTotals.discovered ?? totalConfiguredCount) },
      { label: 'Eligible', value: totalEligibleCount, total: totalConfiguredCount },
      { label: 'Ingested', value: Number(generatedTotals.ingested ?? totalEligibleCount), total: totalEligibleCount },
      { label: 'Extracted', value: Number(generatedTotals.extracted ?? totalEligibleCount), total: totalEligibleCount },
      { label: 'Fully reviewed', value: Number(generatedTotals.reviewed_videos ?? 0), total: totalEligibleCount },
      { label: 'Published', value: Number(generatedTotals.published_videos ?? corpus.videos.length), total: totalEligibleCount },
    ],
  },
];

const showLocalBudget = import.meta.env.PUBLIC_PRODUCTION_BUILD !== 'true';
const budgetTaskNames = ['extraction', 'rephrase', 'benchmark'] as const;
type BudgetTaskName = (typeof budgetTaskNames)[number];
type BudgetTaskStatus = {
  usedTokens: number;
  limitTokens: number | null;
  remainingTokens: number | null;
  calls: number;
  deferred: number;
};

const budgetConfigPath = fileURLToPath(new URL('../../../config/processors.yaml', import.meta.url));
const budgetLedgerPath = fileURLToPath(new URL('../../../data/manifests/table-tennis/llm-budget.json', import.meta.url));
const budgetConfig = existsSync(budgetConfigPath) ? readFileSync(budgetConfigPath, 'utf-8') : '';
const configNumber = (pattern: RegExp, fallback: number) => {
  const match = budgetConfig.match(pattern);
  return match ? Number(match[1]) : fallback;
};
const configText = (pattern: RegExp, fallback: string) => budgetConfig.match(pattern)?.[1] ?? fallback;
const budgetEnabled = configText(/^\s+enabled:\s*(true|false)\s*$/m, 'true') === 'true';
const budgetTimezone = configText(/^\s+timezone:\s*([^\s#]+)\s*$/m, 'local');
const budgetDailyLimit = configNumber(/^\s+daily_token_limit:\s*(\d+)\s*$/m, 500000);
const taskLimit = (task: BudgetTaskName) =>
  configNumber(new RegExp(`^\\s+${task}:\\s*(\\d+)\\s*$`, 'm'), 0);
const emptyBudgetDay = { actual_tokens: 0, reserved_tokens: 0, tasks: {} as Record<string, Record<string, number>> };
const readBudgetLedger = () => {
  if (!existsSync(budgetLedgerPath)) return { days: {} as Record<string, typeof emptyBudgetDay> };
  try {
    return JSON.parse(readFileSync(budgetLedgerPath, 'utf-8')) as {
      days?: Record<string, typeof emptyBudgetDay>;
    };
  } catch {
    return { days: {} as Record<string, typeof emptyBudgetDay> };
  }
};
const budgetLedger = readBudgetLedger();
const budgetDate = new Intl.DateTimeFormat('en-CA', {
  timeZone: budgetTimezone === 'local' || budgetTimezone === 'system' ? undefined : budgetTimezone,
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
}).format(new Date());
const budgetDay = budgetLedger.days?.[budgetDate] ?? emptyBudgetDay;
const budgetUsedTokens = Number(budgetDay.actual_tokens ?? 0) + Number(budgetDay.reserved_tokens ?? 0);
const budgetRemainingTokens = Math.max(0, budgetDailyLimit - budgetUsedTokens);
const budgetPercent = budgetDailyLimit ? Math.min(100, Math.round((budgetUsedTokens / budgetDailyLimit) * 100)) : 0;
const formatTokens = (value: number) => value.toLocaleString('en-US');
const budgetTasks: Record<BudgetTaskName, BudgetTaskStatus> = Object.fromEntries(
  budgetTaskNames.map((task) => {
    const record = budgetDay.tasks?.[task] ?? {};
    const usedTokens = Number(record.actual_tokens ?? 0) + Number(record.reserved_tokens ?? 0);
    const limitTokens = taskLimit(task) || null;
    return [task, {
      usedTokens,
      limitTokens,
      remainingTokens: limitTokens === null ? null : Math.max(0, limitTokens - usedTokens),
      calls: Number(record.calls ?? 0),
      deferred: Number(record.deferred ?? 0),
    } satisfies BudgetTaskStatus];
  }),
) as Record<BudgetTaskName, BudgetTaskStatus>;
const budgetRows = budgetTaskNames.map((task) => {
  const item = budgetTasks[task];
  const limit = item.limitTokens ?? 0;
  return {
    task,
    ...item,
    taskPercent: limit ? Math.min(100, Math.round((item.usedTokens / limit) * 100)) : 0,
    progressLimit: limit || 1,
    progressValue: Math.min(item.usedTokens, limit || 1),
  };
});
---

<BaseLayout title="Source video progress" description="Processing progress by source for the table-tennis knowledge base.">
  <section class="page-intro progress-intro">
    <div class="eyebrow">Pipeline status · updated 16 July 2026</div>
    <h1>Source video progress</h1>
    <p>Discovery, transcript ingestion, Codex extraction, editorial review, and publication status for each configured table-tennis source.</p>
  </section>

  <aside class="progress-alert success"><strong>Generated snapshot</strong><span>Counts below are generated during publish from local processor artifacts. No LLM edits these project totals; the snapshot was generated at {generatedProgress.generated_at}.</span></aside>

  <section class="progress-section">
    <div class="section-kicker">Current corpus</div><h2>Source summary</h2>
    <div class="table-scroll"><table class="progress-table summary-table"><thead><tr><th>Source</th><th>Discovered</th><th>Configured</th><th>Eligible</th><th>Ingested</th><th>Extracted</th><th>Reviewed</th><th>Published</th><th>Accepted</th><th>Rejected</th><th>Evidence</th><th>Concepts</th><th>Visuals proposed</th><th>Visuals verified</th></tr></thead><tbody>
      <tr><th>TT SpinMaster<br/><small>@FreeCoachBradHan</small></th><td>{spinMasterProgress.discovered}</td><td>{summaryStage(Number(spinMasterProgress.configured), Number(spinMasterProgress.discovered))}</td><td>{summaryStage(Number(spinMasterProgress.eligible), Number(spinMasterProgress.configured))}</td><td>{summaryStage(Number(spinMasterProgress.ingested), Number(spinMasterProgress.eligible))}</td><td>{summaryStage(Number(spinMasterProgress.extracted), Number(spinMasterProgress.eligible))}</td><td>{summaryStage(Number(spinMasterProgress.reviewed), Number(spinMasterProgress.eligible))}</td><td>{summaryStage(Number(spinMasterProgress.published), Number(spinMasterProgress.eligible))}</td><td>{spinMasterProgress.accepted} + {spinMasterProgress.deferred} deferred</td><td>{spinMasterProgress.rejected}</td><td>{spinMasterProgress.evidence}</td><td>{spinMasterProgress.concepts}</td><td>{spinMasterProgress.visual_proposed}</td><td>{spinMasterProgress.visual_verified}</td></tr>
      <tr><th>GlobalTTStudio<br/><small>@GlobalTTStudio</small></th><td>{globalProgress.discovered}</td><td>{summaryStage(Number(globalProgress.configured), Number(globalProgress.discovered))}</td><td>{summaryStage(Number(globalProgress.eligible), Number(globalProgress.configured))}</td><td>{summaryStage(Number(globalProgress.ingested), Number(globalProgress.eligible))}</td><td>{summaryStage(Number(globalProgress.extracted), Number(globalProgress.eligible))}</td><td>{summaryStage(Number(globalProgress.reviewed), Number(globalProgress.eligible))}</td><td>{summaryStage(Number(globalProgress.published), Number(globalProgress.eligible))}</td><td>{globalProgress.accepted} + {globalProgress.deferred} deferred</td><td>{globalProgress.rejected}</td><td>{globalProgress.evidence}</td><td>{globalProgress.concepts}</td><td>{globalProgress.visual_proposed}</td><td>{globalProgress.visual_verified}</td></tr>
      <tr class="total"><th>Total configured</th><td>{generatedTotals.discovered}</td><td>{summaryStage(totalConfiguredCount, Number(generatedTotals.discovered))}</td><td>{summaryStage(Number(generatedTotals.eligible), totalConfiguredCount)}</td><td>{summaryStage(Number(generatedTotals.ingested), Number(generatedTotals.eligible))}</td><td>{summaryStage(Number(generatedTotals.extracted), Number(generatedTotals.eligible))}</td><td>{summaryStage(Number(generatedTotals.reviewed_videos), Number(generatedTotals.eligible))}</td><td>{summaryStage(Number(generatedTotals.published_videos), Number(generatedTotals.eligible))}</td><td>{generatedTotals.accepted} + {generatedTotals.deferred} deferred</td><td>{generatedTotals.rejected}</td><td>{generatedTotals.evidence}</td><td>{generatedTotals.concepts} unique</td><td>{generatedTotals.visual_proposed}</td><td>{generatedTotals.visual_verified}</td></tr>
    </tbody></table></div>
    <p class="table-note">Parenthesized percentages use the workflow denominator for that column: configured versus discovered, eligible versus configured, and downstream stages versus eligible. Concept counts overlap between sources. Proposed visual intervals remain non-looping until a reviewer watches and verifies them.</p>
  </section>

  <section class="progress-section">
    <div class="section-kicker">Completion</div><h2>Pipeline progress</h2>
    <p class="progress-explainer">Each percentage shows how far that source has moved through the workflow. Configuration is measured against discovered videos; eligible excludes configured members-only entries, and later stages use the eligible or previously completed stage as their denominator.</p>
    <div class="progress-groups">
      {sourceProgress.map((source) => <article class="progress-group">
        <div class="progress-group-heading"><h3>{source.name}</h3><span>{source.detail}</span></div>
        <div class="progress-bars">
          {source.stages.map((stage) => { const percentage = percent(stage.value, stage.total); return <div class="progress-item">
            <div class="progress-item-heading"><strong>{stage.label}</strong><span>{percentage}%</span></div>
            <progress max={stage.total} value={stage.value} aria-label={`${source.name}: ${stage.label} ${percentage}%`}>{percentage}%</progress>
            <small>{stage.value} / {stage.total}</small>
          </div>; })}
        </div>
      </article>)}
    </div>
  </section>

  {showLocalBudget && <section class="progress-section llm-budget-section">
    <div class="section-kicker">Local operator guard</div><h2>LLM budget</h2>
    <p class="progress-explainer">Private Codex usage for the current day. The ledger is local-only and never copied into the public corpus. Adjust the daily and task limits in <code>config/processors.yaml</code>.</p>
    {!budgetEnabled && <aside class="progress-alert warning"><strong>Budget disabled</strong><span>The daily LLM guard is disabled in the processor configuration.</span></aside>}
    <div class="llm-budget-summary">
      <div class="llm-budget-total">
        <div class="llm-budget-total-heading"><strong>{formatTokens(budgetUsedTokens)}</strong><span>of {formatTokens(budgetDailyLimit)} tokens used</span><em>{budgetPercent}%</em></div>
        <progress max={budgetDailyLimit || 1} value={Math.min(budgetUsedTokens, budgetDailyLimit || 1)} aria-label={`LLM budget ${budgetPercent}% used`}>{budgetPercent}%</progress>
        <p>{formatTokens(budgetRemainingTokens)} tokens remain for {budgetDate} ({budgetTimezone}). Reserved work is included so concurrent or interrupted runs do not overbook the allowance.</p>
      </div>
      <dl class="llm-budget-facts">
        <div><dt>Ledger</dt><dd>{existsSync(budgetLedgerPath) ? 'Active' : 'No calls recorded'}</dd></div>
        <div><dt>Scope</dt><dd>Table Tennis KB</dd></div>
        <div><dt>Source</dt><dd>Local processor manifest</dd></div>
      </dl>
    </div>
    <div class="table-scroll"><table class="progress-table llm-budget-table"><thead><tr><th>Task</th><th>Used</th><th>Limit</th><th>Remaining</th><th>Calls</th><th>Deferred</th></tr></thead><tbody>
      {budgetRows.map((item) => <tr><th><span class="llm-budget-task-name">{item.task}</span><progress max={item.progressLimit} value={item.progressValue} aria-label={`${item.task} budget ${item.taskPercent}% used`}>{item.taskPercent}%</progress></th><td>{formatTokens(item.usedTokens)}</td><td>{item.limitTokens === null ? 'Unlimited' : formatTokens(item.limitTokens)}</td><td>{item.remainingTokens === null ? 'Unlimited' : formatTokens(item.remainingTokens)}</td><td>{item.calls}</td><td>{item.deferred}</td></tr>)}
    </tbody></table></div>
    <p class="table-note">Task calls are estimated before Codex starts and reconciled with reported usage afterward. When the allowance is exhausted, extraction, rephrasing, and benchmarking are deferred rather than started.</p>
  </section>}

  <section class="progress-section">
    <div class="section-kicker">Definitions</div><h2>What each state means</h2>
    <dl class="state-definitions">
      <div><dt>Discovered</dt><dd>Metadata appeared in a channel manifest; relevance and caption availability are not guaranteed.</dd></div>
      <div><dt>Configured</dt><dd>The video is explicitly listed in the source configuration.</dd></div>
      <div><dt>Eligible</dt><dd>The configured video is selected and publicly accessible enough to process; members-only entries remain configured but are excluded from this stage.</dd></div>
      <div><dt>Ingested</dt><dd>A private normalized transcript and metadata file exist locally.</dd></div>
      <div><dt>Extracted</dt><dd>A private schema-validated Codex candidate artifact exists.</dd></div>
      <div><dt>Reviewed</dt><dd>Every extracted candidate has an accepted or rejected decision.</dd></div>
      <div><dt>Published</dt><dd>At least one approved evidence moment appears in the public corpus.</dd></div>
      <div><dt>Visual verified</dt><dd>A reviewer watched the interval and confirmed it demonstrates the concept.</dd></div>
    </dl>
  </section>

  <section class="progress-section">
    <div class="section-kicker">Backlog</div><h2>Outstanding work</h2>
    <div class="table-scroll"><table class="progress-table"><thead><tr><th>Work item</th><th>Count</th><th>Recommended action</th></tr></thead><tbody>
      <tr><th>Deferred extracted candidates</th><td>{generatedTotals.deferred}</td><td>Review new taxonomy proposals and weak matches before another expansion pass.</td></tr>
      <tr><th>Proposed visuals requiring viewing</th><td>{generatedTotals.visual_proposed}</td><td>Watch complete intervals and verify only genuine demonstrations.</td></tr>
      <tr><th>Single-source concepts</th><td>{generatedTotals.single_source_concepts}</td><td>Select independent supporting sources instead of duplicate moments.</td></tr>
      <tr><th>Members-only configured videos</th><td>{globalProgress.members_only}</td><td>Leave unprocessed unless access and processing rights are explicit.</td></tr>
      <tr><th>Published videos with review backlog</th><td>{generatedTotals.published_with_review_backlog}</td><td>Continue resolving deferred candidates; only incorporated evidence is currently public.</td></tr>
      <tr><th>Unselected TT SpinMaster discoveries</th><td>{spinMasterProgress.unselected}</td><td>Curate by coverage gap; do not bulk-ingest automatically.</td></tr>
      <tr><th>Unselected GlobalTTStudio discoveries</th><td>{globalProgress.unselected}</td><td>Curate by missing topic, source diversity, or useful visual demonstration.</td></tr>
    </tbody></table></div>
  </section>

  <section class="progress-section inventories" id="videos-by-source">
    <div class="section-kicker">Source inventory</div><h2>Videos by source</h2>
    <p class="table-note">Each source includes its complete trustworthy discovery catalog where available. State labels distinguish public knowledge-base evidence from videos that are merely listed by the channel.</p>
    <details><summary><strong>TT SpinMaster</strong><span>{spinMasterProgress.published} published / {Number(spinMasterProgress.extracted) - Number(spinMasterProgress.published)} extracted/reviewing / {spinMasterProgress.unselected} unselected</span></summary><div class="table-scroll"><table class="progress-table"><thead><tr><th>State</th><th>Video</th><th>Title</th></tr></thead><tbody>{sixthBatchVideos.map((video) => <tr><td><span class="catalog-state extracted">Extracted / review</span></td><td><a href={`https://www.youtube.com/watch?v=${video.id}`} target="_blank" rel="noreferrer"><code>{video.id}</code></a></td><td>{video.title}</td></tr>)}{spinMasterVideos.map((video) => <tr><td><span class="catalog-state published">Published</span></td><td><a href={`https://www.youtube.com/watch?v=${video.id}`} target="_blank" rel="noreferrer"><code>{video.id}</code></a></td><td>{video.title}</td></tr>)}</tbody></table></div><p class="inventory-note">Counts are generated from local processor artifacts during publish. Unselected channel discoveries have not entered the processing pipeline.</p></details>
    <details id="globalttstudio-videos"><summary><strong>GlobalTTStudio</strong><span>{globalProgress.discovered} discovered / {globalEligibleCount} published / {globalInaccessibleCount} members-only</span></summary>
      <p class="inventory-note">Metadata-only discovery on 15 July 2026. “Discovered” means listed by the channel; it does not mean selected, transcribed, extracted, or reviewed.</p>
      <div class="table-scroll"><table class="progress-table catalog-table"><thead><tr><th>State</th><th>Video</th><th>Title</th></tr></thead><tbody>{globalCatalogVideos.map((video) => <tr><td><span class:list={['catalog-state', globalCatalogState(video.id).toLowerCase()]}>{globalCatalogState(video.id)}</span></td><td><a href={video.url} target="_blank" rel="noreferrer"><code>{video.id}</code></a></td><td>{video.title}</td></tr>)}</tbody></table></div>
    </details>
  </section>
</BaseLayout>
