---
import catalogData from '../../public/data/catalog.json';
import BaseLayout from '../layouts/BaseLayout.astro';
import type { CatalogEntry } from '../types';
const entries = (catalogData as { knowledge_bases: CatalogEntry[] }).knowledge_bases;
const base = import.meta.env.BASE_URL;
---
<BaseLayout><section class="hero"><div class="eyebrow">Source-grounded video knowledge</div><h1>Choose a knowledge base.<br /><em>See the exact moment.</em></h1><p class="hero-copy">Each topic has its own sources, taxonomy, concepts, review workflow, and timestamped evidence.</p></section><section class="concept-grid" aria-label="Knowledge bases">{entries.map((kb) => <a class="concept-card" href={`${base}kb/${kb.id}/`}><div class="card-meta"><span>Knowledge base</span><span>{kb.concept_count} concepts</span></div><h2>{kb.name}</h2><p>{kb.description}</p><div class="aliases">{kb.video_count} source videos</div></a>)}</section></BaseLayout>
