---
import { corpora } from '../../../../corpora';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import type { Corpus } from '../../../../types';

export function getStaticPaths() { return corpora.map((corpus) => ({ params: { kb: corpus.knowledge_base.id }, props: { corpus } })); }
interface Props { corpus: Corpus }
const { corpus } = Astro.props;
const root = `${import.meta.env.BASE_URL}kb/${corpus.knowledge_base.id}`;
const slugify = (value: string) => value.trim().toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
const channels = [...new Set(corpus.videos.map((video) => video.channel_name.trim()))].sort((a, b) => a.localeCompare(b));
---

<BaseLayout title={`${corpus.knowledge_base.name} video sources`} kbId={corpus.knowledge_base.id}>
  <section class="page-intro">
    <div class="eyebrow">Source library</div>
    <h1>Video sources</h1>
    <p>Choose a channel, then browse its lessons in batches of 20.</p>
  </section>
  <section class="video-channel-directory" aria-label="Video channels">
    {channels.map((channel) => {
      const videos = corpus.videos.filter((video) => video.channel_name.trim() === channel);
      const pages = Math.ceil(videos.length / 20);
      const channelRoot = `${root}/videos/${slugify(channel)}`;
      return <article class="video-channel-card">
        <div>
          <p class="eyebrow">Channel</p>
          <h2><a href={`${channelRoot}/`}>{channel}</a></h2>
          <p>{videos.length} source video{videos.length === 1 ? '' : 's'} · {pages} batch{pages === 1 ? '' : 'es'}</p>
        </div>
        <nav aria-label={`Batches for ${channel}`} class="video-batch-links">
          {Array.from({ length: pages }, (_, index) => <a href={`${channelRoot}/${index + 1}/`}>Batch {index + 1}</a>)}
        </nav>
      </article>;
    })}
  </section>
</BaseLayout>
