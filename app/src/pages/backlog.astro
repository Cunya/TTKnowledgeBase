---
import { readFileSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import BaseLayout from '../layouts/BaseLayout.astro';

type Priority = 'P0' | 'P1' | 'P2';
type BacklogItem = {
  id: string;
  priority: Priority;
  number: number;
  title: string;
  why: string;
  work: string;
  dependencies: string;
  doneWhen: string;
  status: string;
  state: 'complete' | 'planned' | 'blocked' | 'in_progress' | 'open';
};

const backlogPath = fileURLToPath(new URL('../../../docs/prioritized-backlog-2026-07-15.md', import.meta.url));
const backlogText = readFileSync(backlogPath, 'utf-8');
const headingPattern = /^###\s+(P[012])-(\d+)\s+(.+)$/gm;
const headings = [...backlogText.matchAll(headingPattern)];
const cleanHeading = (value: string) => value
  .replace(/^[\s-—–]+/, '')
  .replace(/\s+\(new \d{4}-\d{2}-\d{2}\)$/, '')
  .trim();
const field = (block: string, label: string) => {
  const match = block.match(new RegExp(`\\*\\*${label}:\\*\\*\\s*([^\\n]+)`, 'i'));
  return match?.[1]?.replace(/\*\*/g, '').trim() ?? '';
};
const statusFor = (block: string) => field(block, 'Status') || 'Open';
const stateFor = (status: string): BacklogItem['state'] => {
  const normalized = status.toLowerCase();
  if (normalized.includes('planned')) return 'planned';
  if (normalized.includes('blocked')) return 'blocked';
  if (normalized.includes('complete')) return 'complete';
  if (normalized.includes('in progress') || normalized.includes('in-progress')) return 'in_progress';
  return 'open';
};
const backlogItemOrder = (item: BacklogItem) => item.state === 'complete' ? 1 : 0;
const fallbackWhy = (block: string) => block
  .split('\n')
  .map((line) => line.trim())
  .find((line) => line && !line.startsWith('**') && !line.startsWith('#')) ?? 'Work item recorded in the project backlog.';

const items: BacklogItem[] = headings.map((heading, index) => {
  const start = heading.index! + heading[0].length;
  const end = headings[index + 1]?.index ?? backlogText.length;
  const block = backlogText.slice(start, end);
  const priority = heading[1] as Priority;
  const number = Number(heading[2]);
  const status = statusFor(block);
  return {
    id: `${priority}-${String(number).padStart(2, '0')}`,
    priority,
    number,
    title: cleanHeading(heading[3]),
    why: field(block, 'Why') || fallbackWhy(block),
    work: field(block, 'Work'),
    dependencies: field(block, 'Dependencies'),
    doneWhen: field(block, 'Done when'),
    status,
    state: stateFor(status),
  };
});

const featureAreaDefinitions = [
  {
    id: 'trust-and-source-safety',
    label: 'Trust and source safety',
    description: 'Keep acquisition, quotation, takedown, and public/private boundaries defensible.',
    features: [
      { id: 'excerpt-and-attribution-safety', label: 'Excerpt and attribution safety', description: 'Keep editorial wording distinct from source language and preserve defensible attribution.', ids: ['P0-01', 'P1-17'] },
      { id: 'source-governance', label: 'Source governance', description: 'Define acquisition, removal, permissions, and public/private boundaries.', ids: ['P0-02', 'P0-04', 'P0-05', 'P0-07', 'P2-10'] },
      { id: 'private-preservation-mode', label: 'Private preservation mode', description: 'Make a personal fallback possible without mixing offline material into the public site.', ids: ['P1-08', 'P1-09'] },
    ],
  },
  {
    id: 'evidence-and-content-quality',
    label: 'Evidence and content quality',
    description: 'Make moments useful, complete, diverse, and meaningful instead of merely numerous.',
    features: [
      { id: 'moment-quality', label: 'Moment quality', description: 'Select complete, meaningful windows and remove repetition from the evidence library.', ids: ['P1-01', 'P1-03', 'P1-13', 'P1-14'] },
      { id: 'evidence-coverage', label: 'Evidence coverage', description: 'Strengthen cross-video support and make each concept’s evidence hierarchy explicit.', ids: ['P1-05', 'P1-06'] },
      { id: 'knowledge-structure', label: 'Knowledge structure', description: 'Resolve taxonomy placeholders into durable concepts and relationships.', ids: ['P1-07', 'P1-21'] },
    ],
  },
  {
    id: 'publishing-and-navigation',
    label: 'Publishing and navigation',
    description: 'Keep generated pages, links, encoding, and public artifacts reliable and calm to use.',
    features: [
      { id: 'publish-integrity', label: 'Publish integrity', description: 'Keep canonical data fresh, allowlisted, deduplicated, and free of encoding regressions.', ids: ['P0-03', 'P1-11', 'P2-01', 'P2-02'] },
      { id: 'navigation-and-toc', label: 'Navigation and table of contents', description: 'Make deployment routes, anchors, and deterministic video TOCs dependable.', ids: ['P0-06', 'P1-10', 'P2-06'] },
      { id: 'viewer-experience', label: 'Viewer experience', description: 'Keep source attribution and embedded playback clear without over-emphasizing source titles.', ids: ['P1-12', 'P1-18', 'P2-04', 'P2-05'] },
    ],
  },
  {
    id: 'operations-and-automation',
    label: 'Operations and automation',
    description: 'Turn processing, budgets, provenance, source monitoring, and daily runs into observable routines.',
    features: [
      { id: 'pipeline-orchestration', label: 'Pipeline orchestration', description: 'Drain pending work safely, budget model calls, and support unattended daily processing.', ids: ['P1-02', 'P1-15', 'P1-16', 'P1-19', 'P1-20'] },
      { id: 'observability-and-reporting', label: 'Observability and reporting', description: 'Expose progress, extraction cost, provenance, and knowledge-graph quality.', ids: ['P1-04', 'P2-07', 'P2-09'] },
      { id: 'maintenance-and-monitoring', label: 'Maintenance and source monitoring', description: 'Keep dependencies pinned and detect source availability changes before they surprise publishing.', ids: ['P2-03', 'P2-08', 'P1-22'] },
    ],
  },
];
const featureAreas = featureAreaDefinitions.map((area) => {
  const features = area.features.map((feature) => {
    const featureItems = feature.ids
      .map((id) => items.find((item) => item.id === id))
      .filter((item): item is BacklogItem => Boolean(item))
      .sort((left, right) => backlogItemOrder(left) - backlogItemOrder(right));
    return { ...feature, items: featureItems, complete: featureItems.filter((item) => item.state === 'complete').length };
  });
  const areaItems = features.flatMap((feature) => feature.items);
  return { ...area, features, items: areaItems, complete: areaItems.filter((item) => item.state === 'complete').length };
});
const completeCount = items.filter((item) => item.state === 'complete').length;
const openCount = items.length - completeCount;
const plannedCount = items.filter((item) => item.state === 'planned').length;
const backlogDate = backlogText.match(/Last refreshed:\s*([^\n]+)/)?.[1]?.trim() ?? 'Not recorded';
const stateLabel = (state: BacklogItem['state']) => ({ complete: 'Complete', planned: 'Planned', blocked: 'Blocked', in_progress: 'In progress', open: 'Open' })[state];
---

<BaseLayout title="Prioritized backlog" description="Local-only view of the MomentGraph project backlog and next work. ">
  <section class="page-intro backlog-intro">
    <div class="eyebrow">Local operator view · planning source of truth</div>
    <h1>What should happen next?</h1>
    <p>A readable view of the prioritized backlog, organized around the product features and outcomes the work supports. This page is generated from <code>docs/prioritized-backlog-2026-07-15.md</code> and is intentionally excluded from the public GitHub Pages build.</p>
    <div class="backlog-meta"><span>Last refreshed {backlogDate}</span><span>{items.length} tracked items</span><span>{openCount} still active</span></div>
  </section>

  <section class="backlog-summary" aria-label="Backlog summary">
    <div><strong>{openCount}</strong><span>active items</span></div>
    <div><strong>{completeCount}</strong><span>complete</span></div>
    <div><strong>{plannedCount}</strong><span>planned</span></div>
    <div><strong>{items.filter((item) => item.priority === 'P0' && item.state !== 'complete').length}</strong><span>open trust gates</span></div>
  </section>

  <section class="backlog-section">
    <div class="section-kicker">At a glance</div>
    <h2>Feature-area map</h2>
    <p class="backlog-lead">The backlog has three levels: broad feature areas, the features inside them, and the actionable P0/P1/P2 items that deliver each feature.</p>
    <div class="backlog-lanes">
      {featureAreas.map((area, index) => {
        const percent = area.items.length ? Math.round((area.complete / area.items.length) * 100) : 0;
        return <a class="backlog-lane" href={`#area-${area.id}`}>
          <div><span>Area {String(index + 1).padStart(2, '0')}</span><strong>{area.label}</strong></div>
          <p>{area.features.length} features · {area.complete} of {area.items.length} complete</p>
          <progress max={area.items.length || 1} value={area.complete} aria-label={`${area.label}: ${percent}% complete`}>{percent}%</progress>
          <small>{percent}% complete</small>
        </a>;
      })}
    </div>
  </section>

  <section class="backlog-section" id="active-work">
    <div class="section-kicker">Feature areas and features</div>
    <h2>Work grouped by outcome</h2>
    <p class="backlog-lead">Start with a feature area, choose one of its features, then expand a backlog item for its reason, implementation boundary, dependencies, and acceptance criteria. Completed items remain visible as history, and every row retains its P0/P1/P2 priority.</p>
    <div class="backlog-status-key" aria-label="Backlog status colors">
      <span class="backlog-key-open"><i></i>Open</span>
      <span class="backlog-key-in-progress"><i></i>In progress</span>
      <span class="backlog-key-planned"><i></i>Planned</span>
      <span class="backlog-key-blocked"><i></i>Blocked</span>
      <span class="backlog-key-complete"><i></i>Complete</span>
    </div>
    <div class="backlog-groups">
      {featureAreas.map((area) => <section class="backlog-group backlog-area" id={`area-${area.id}`}>
        <header class="backlog-group-heading backlog-area-heading"><div><span>Feature area</span><h3>{area.label}</h3><p>{area.description}</p></div><small>{area.features.length} features · {area.complete}/{area.items.length} complete</small></header>
        <div class="backlog-features">
          {area.features.map((feature) => <section class="backlog-feature" id={`feature-${feature.id}`}>
            <header class="backlog-feature-heading"><div><span>Feature</span><h4>{feature.label}</h4><p>{feature.description}</p></div><small>{feature.complete}/{feature.items.length} complete</small></header>
            <div class="backlog-items">
          {feature.items.map((item) => <details class:list={['backlog-item', `backlog-item-${item.state}`]} open={item.priority === 'P0' && item.state !== 'complete'} id={item.id.toLowerCase()}>
            <summary><span class="backlog-item-id">{item.id}</span><strong>{item.title}</strong><em>{item.priority} · {stateLabel(item.state)}</em></summary>
            <div class="backlog-item-body">
              <div class="backlog-copy backlog-status-copy"><span class="backlog-label">Status</span><p>{item.status}</p></div>
              <div class="backlog-copy"><span class="backlog-label">Why it matters</span><p>{item.why}</p></div>
              {item.work && <div class="backlog-copy"><span class="backlog-label">Work</span><p>{item.work}</p></div>}
              {item.dependencies && <div class="backlog-copy"><span class="backlog-label">Dependencies</span><p>{item.dependencies}</p></div>}
              {item.doneWhen && <div class="backlog-copy backlog-acceptance"><span class="backlog-label">Acceptance</span><p>{item.doneWhen}</p></div>}
            </div>
          </details>)}
            </div>
          </section>)}
        </div>
      </section>)}
    </div>
  </section>

  <aside class="backlog-notice"><strong>Local-only operator page</strong><span>The backlog can include private operational findings and unfinished work. It is available during local development at <code>/backlog/</code> and is removed before a production GitHub Pages build.</span></aside>
</BaseLayout>
