---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  kbId?: string;
}

const {
  title = 'MomentGraph',
  description = 'Source-grounded concepts demonstrated by exact moments in video.',
  kbId,
} = Astro.props;
const base = import.meta.env.BASE_URL;
// Local dev and preview builds keep operational pages visible. The public build
// sets PUBLIC_PRODUCTION_BUILD while it temporarily removes those page files.
const showLocalDocumentation = import.meta.env.PUBLIC_PRODUCTION_BUILD !== 'true';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <script is:inline>
      const savedTheme = localStorage.getItem('momentgraph-theme');
      if (savedTheme === 'dark' || (!savedTheme && matchMedia('(prefers-color-scheme: dark)').matches)) document.documentElement.dataset.theme = 'dark';
    </script>
    <title>{title === 'MomentGraph' ? title : `${title} · MomentGraph`}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={base} aria-label="MomentGraph home">
        <span class="brand-mark">MG</span>
        <span>MomentGraph</span>
      </a>
      <nav aria-label="Primary navigation">
        <a href={kbId ? `${base}kb/${kbId}/` : base}>Knowledge bases</a>
        {kbId && <a href={`${base}kb/${kbId}/videos/`}>Videos</a>}
        <a href={`${base}methodology/`}>Method</a>
        {showLocalDocumentation && <a href={`${base}dashboard/`}>Dashboard</a>}
        <a class="support-nav" href={`${base}support/`}>Support</a>
        <button class="theme-toggle" type="button" aria-label="Toggle dark mode" data-theme-toggle>Dark mode</button>
      </nav>
    </header>
    <main><slot /></main>
    <footer>
      <p>Every knowledge item links back to its source moment. Independent educational project. <a href={`${base}support/`}>Support its development</a>.</p>
    </footer>
    <script is:inline>
      const toggle = document.querySelector('[data-theme-toggle]');
      const updateThemeLabel = () => { if (toggle) toggle.textContent = document.documentElement.dataset.theme === 'dark' ? 'Light mode' : 'Dark mode'; };
      updateThemeLabel();
      toggle?.addEventListener('click', () => { const dark = document.documentElement.dataset.theme !== 'dark'; document.documentElement.dataset.theme = dark ? 'dark' : 'light'; localStorage.setItem('momentgraph-theme', dark ? 'dark' : 'light'); updateThemeLabel(); });
    </script>
  </body>
</html>
