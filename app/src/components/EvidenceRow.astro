---
import type { Evidence, Video } from '../types';

interface Citation { item: Evidence; index: number }
interface Props { citations: Citation[]; video?: Video; initialIndex: number }
const { citations, video, initialIndex } = Astro.props;
const item = citations[0].item;
const active = citations.some(({ index }) => index === initialIndex);
const formatTime = (milliseconds: number) => {
  const total = Math.floor(milliseconds / 1000);
  return `${Math.floor(total / 60)}:${String(total % 60).padStart(2, '0')}`;
};
---

<article class:list={['evidence-row', { active }]} id={`moment-${item.id}`}>
  {citations.slice(1).map(({ item: citation }) => <span id={`moment-${citation.id}`} class="evidence-citation-anchor" aria-hidden="true"></span>)}
  <div class="evidence-row-content">
    <div class="evidence-row-meta"><span>{item.evidence_type.replaceAll('_', ' ')}</span><small>{citations.length} moment{citations.length === 1 ? '' : 's'}</small></div>
    <div>
      <blockquote>{item.excerpt}</blockquote>
      <p>{item.reason}</p>
      <small>{item.visual_source ? `${item.visual_status === 'verified_visual_demo' ? 'Verified visual' : 'Proposed visual — not yet reviewed'} · ${item.visual_source.note}` : 'Spoken source; visual example not yet selected.'}</small>
      <p class="entry-source"><span>Source video</span>{video?.title ?? item.source.video_id}{video?.channel_name && <small>{video.channel_name}</small>}</p>
    </div>
  </div>
  <div class="evidence-row-actions">
    {citations.map(({ item: citation }, citationIndex) => {
      const verifiedVisual = citation.visual_status === 'verified_visual_demo' && citation.visual_source?.selection_method === 'manual_review';
      const clip = citation.visual_source ?? { ...citation.source, end_ms: citation.spoken_context_end_ms ?? citation.source.end_ms };
      const spokenEnd = citation.spoken_context_end_ms ?? citation.source.end_ms;
      return <div class="evidence-citation-actions">
        {citation.visual_source && <button class="play-moment" data-video={clip.video_id} data-start={Math.floor(clip.start_ms / 1000)} data-end={Math.ceil(clip.end_ms / 1000)} data-loopable={String(verifiedVisual)}>{verifiedVisual ? 'Play verified visual' : 'Play proposed visual'}<span>{formatTime(clip.start_ms)}–{formatTime(clip.end_ms)}</span></button>}
        <button class="play-moment" data-video={citation.source.video_id} data-start={Math.floor(citation.source.start_ms / 1000)} data-end={Math.ceil(spokenEnd / 1000)} data-loopable="false">{citations.length > 1 ? `Play citation ${citationIndex + 1}` : 'Play explanation'}<span>{formatTime(citation.source.start_ms)}–{formatTime(spokenEnd)}</span></button>
        <a class="youtube-timestamp-link" href={citation.source.url} target="_blank" rel="noreferrer" aria-label={`Open this source timestamp on YouTube at ${formatTime(citation.source.start_ms)}`}>Open on YouTube<span>{formatTime(citation.source.start_ms)} ↗</span></a>
      </div>;
    })}
  </div>
</article>
