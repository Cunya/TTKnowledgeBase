---
import type { Concept, KnowledgeNavigation, TopicNode } from '../types';
interface Props { concepts: Concept[]; root: string; navigation: KnowledgeNavigation }
const { concepts, root, navigation } = Astro.props;
const conceptMap = Object.fromEntries(concepts.map((concept) => [concept.id, concept]));
type Branch = { node: TopicNode; path: TopicNode[]; code: string; depth: number };
const branches: Branch[] = [];
const flatten = (nodes: TopicNode[], path: TopicNode[] = [], prefix = '') => {
  nodes.forEach((node, index) => {
    const code = prefix ? `${prefix}.${index + 1}` : `${index + 1}`;
    const nextPath = [...path, node];
    branches.push({ node, path: nextPath, code, depth: path.length });
    flatten(node.children, nextPath, code);
  });
};
flatten(navigation.sections);
const linksFor = (concept: Concept) => concept.relations.flatMap((relation) => conceptMap[relation.target_concept_id] ? [{ relation: relation.relation_type, target: conceptMap[relation.target_concept_id] }] : []);
---

<div class="connection-atlas">
  <div class="atlas-key"><span>Topic path</span><span>Concepts and transcript-supported connections</span></div>
  {branches.map(({ node, path, code, depth }) => (
    <section class:list={['atlas-row', `atlas-depth-${Math.min(depth, 3)}`]} style={`--depth: ${depth}`} id={`topic-${node.id}`}>
      <header>
        <div class="atlas-code">{code}</div>
        <div class="atlas-parents">{path.slice(0, -1).map((parent) => parent.label).join(' / ')}</div>
        <h2>{node.label}</h2>
        {node.description && <p>{node.description}</p>}
      </header>
      <div class="atlas-content">
        {node.concept_ids.length === 0 ? <p class="atlas-branch-note">Contains {node.children.length} deeper section{node.children.length === 1 ? '' : 's'}.</p> : node.concept_ids.map((id) => conceptMap[id] && (
          <article class="atlas-concept">
            <a class="atlas-concept-title" href={`${root}/concepts/${conceptMap[id].slug}/`}><strong>{conceptMap[id].label}</strong><span>{conceptMap[id].concept_type}</span></a>
            {linksFor(conceptMap[id]).length > 0 && <div class="atlas-links">{linksFor(conceptMap[id]).map(({ relation, target }) => <a href={`${root}/concepts/${target.slug}/`}><span>{relation.replaceAll('_', ' ')}</span><strong>{target.label}</strong><b aria-hidden="true">→</b></a>)}</div>}
          </article>
        ))}
      </div>
    </section>
  ))}
</div>
